# Copy to .env, fill in what you have, then run scripts/secrets.sh.
# Empty values are skipped — an unconfigured provider is inert (no login
# button, its /start 503s), so you can deploy with any subset.

# Signing secret for Datasette cookies/state. Leave empty and secrets.sh will
# generate one and write it back here. Must stay stable across deploys.
DATASETTE_SECRET=

# GitHub — OAuth App with callback https://<app>.fly.dev/-/github-auth/callback
DATASETTE_GITHUB_CLIENT_ID=
DATASETTE_GITHUB_CLIENT_SECRET=

# Discord — application with redirect https://<app>.fly.dev/-/discord-auth/callback
DATASETTE_DISCORD_CLIENT_ID=
DATASETTE_DISCORD_CLIENT_SECRET=

# Bluesky — no app registration and no secret: the instance serves its own
# client-metadata document. Just the public URL of the deployed app.
DATASETTE_BLUESKY_PUBLIC_URL=https://accounts-providers-fly.fly.dev
